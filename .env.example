# Database
DATABASE_URL=postgresql+asyncpg://trackboard:trackboard_dev@localhost:5432/trackboard
DB_PASSWORD=trackboard_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
ENVIRONMENT=development
DEBUG=true
JWT_SECRET=change-me-to-a-random-64-char-string
SECRET_ENCRYPTION_KEY=change-me-to-a-different-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=http://localhost:\d+

# Optional AI provider defaults
OPENAI_API_KEY=
OPENAI_BASE_URL=
ALLOW_PRIVATE_AI_ENDPOINTS=false

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
